{
  "name": "toggle-explorer-gitignore",
  "displayName": "Toggle Explorer Gitignore",
  "description": "Status bar + command to toggle explorer.excludeGitIgnore",
  "version": "0.3.0",
  "publisher": "local",
  "private": true,
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:toggleExplorerGitignore.toggle"
  ],
  "icon": "images/icon.png",
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "toggleExplorerGitignore.toggle",
        "title": "Toggle Explorer: Exclude Git Ignore"
      }
    ],
    "keybindings": [
      {
        "command": "toggleExplorerGitignore.toggle",
        "key": "ctrl+shift+g",
        "mac": "cmd+shift+g"
      }
    ],
    "configuration": {
      "title": "Toggle Explorer Gitignore",
      "properties": {
        "toggleExplorerGitignore.showStatusBarItem": {
          "type": "boolean",
          "default": true,
          "description": "Показывать кнопку в статус-баре"
        },
        "toggleExplorerGitignore.multiRootBehavior": {
          "type": "string",
          "enum": [
            "all",
            "ask"
          ],
          "default": "all",
          "enumDescriptions": [
            "Применять ко всем папкам workspace",
            "Спрашивать для каждой папки"
          ],
          "description": "Поведение при Multi-root workspace"
        }
      }
    }
  },
  "scripts": {
    "compile": "node build.js",
    "watch": "node build.js --watch",
    "vscode:prepublish": "node build.js --production",
    "vsix": "vsce package --no-dependencies --allow-missing-repository",
    "gen-icon": "node scripts/gen-icon.js",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.2.2",
    "esbuild": "^0.24.0",
    "eslint": "^9.0.0",
    "typescript": "^5.7.0"
  }
}
